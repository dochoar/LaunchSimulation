# ─── Local LLM via Ollama (default — CPU optimised for i7-8750H / 16 GB RAM) ───
# Install Ollama: https://ollama.com
# Then run: ollama pull qwen2.5:7b

LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:7b

# Boost model (Ethnographer + Chronicler) — same model on CPU.
# Replace with a cloud key + model if you want faster/stronger results.
LLM_BOOST_API_KEY=ollama
LLM_BOOST_BASE_URL=http://localhost:11434/v1
LLM_BOOST_MODEL_NAME=qwen2.5:7b

# ─── Alternative cloud models (comment out Ollama block above) ───────────────
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini
# LLM_BOOST_MODEL_NAME=gpt-4o

# ─── Infrastructure ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./launchsim.db
CHROMA_PERSIST_DIR=./chroma_db

APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
